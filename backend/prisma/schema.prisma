  FRIENDLY_WIN
  // Расход
  BATTLE_BET         // ставка в батле
  BATTLE_COMMISSION  // 10% комиссия стола
  BOT_LOSS           // проигрыш боту (Фаза 2)
  ATTEMPT_PURCHASE   // покупка попытки
  ITEM_PURCHASE      // покупка скина/рамки
  CLAN_CONTRIBUTION  // взнос в казну клана
  TOURNAMENT_ENTRY   // взнос в турнир
  WITHDRAWAL         // вывод (v6)
  BATTLE_DONATION    // донат зрителя в батл
  CLAN_WAR_WIN       // выигрыш в клановой войне
  COUNTRY_WAR_WIN    // выигрыш в войне между странами
  TOURNAMENT_WIN     // выигрыш в турнире
  TON_DEPOSIT        // пополнение через TON
  WALLET_UNLOCK      // разовый платёж за подключение кошелька
  PUZZLE_REWARD      // награда за прохождение урока/задачи
  TRADE_BUY          // покупка монет через биржу
