{
  "name": "chesscoin-backend",
  "version": "5.8.1",
  "private": true,
  "scripts": {
    "dev": "tsx --tsconfig tsconfig.json -r tsconfig-paths/register watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy",
    "migrate:dev": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "tsx -r tsconfig-paths/register prisma/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1009.0",
    "@prisma/client": "^5.10.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@telegram-apps/init-data-node": "^1.1.4",
    "chess.js": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^7.2.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "node-cron": "^3.0.3",
    "socket.io": "^4.7.4",
    "stockfish": "^16.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.7.1",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^6.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.11.25",
    "@types/node-cron": "^3.0.11",
    "@types/uuid": "^9.0.8",
    "prisma": "^5.10.0",
    "tsc-alias": "^1.8.8",
    "typescript": "^5.4.2"
  }
}
