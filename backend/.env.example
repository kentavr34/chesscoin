# ─────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────
NODE_ENV=development
SERVER_PORT=3000
DEBUG=true
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────
DATABASE_URL="postgresql://chesscoin:chesscoin_pass@localhost:5432/chesscoin?schema=public"

# ─────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ─────────────────────────────────────────
# JWT
# ─────────────────────────────────────────
JWT_ACCESS_SECRET=dev_access_secret_change_in_production
JWT_ACCESS_EXPIRES=2h
JWT_REFRESH_SECRET=dev_refresh_secret_change_in_production
JWT_REFRESH_EXPIRES=7d

# ─────────────────────────────────────────
# TELEGRAM
# ─────────────────────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_HERE
# Секрет для Bot API запросов из Python бота
BOT_API_SECRET=internal_bot_secret_change_me

# ─────────────────────────────────────────
# S3 (для загрузки аватаров)
# ─────────────────────────────────────────
S3_ENDPOINT=https://s3.timeweb.cloud
S3_REGION=ru-1
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY=your_access_key
S3_SECRET_ACCESS_KEY=your_secret_key

# ─────────────────────────────────────────
# ЭКОНОМИКА — ФАЗА 1
# ─────────────────────────────────────────
# Эмиссия
HARD_CAP=100000000000
EMISSION_CAP=30000000000

# Стартовые бонусы
WELCOME_BONUS=5000
REFERRAL_FIRST_GAME_BONUS=3000

# Попытки
MAX_ATTEMPTS=3
ATTEMPT_RESTORE_HOURS=8
ATTEMPT_PRICE=1000
MAX_PURCHASED_ATTEMPTS=3

# Реферальная система
REFERRER_INCOME_PERCENT=50
SUB_REFERRER_INCOME_PERCENT=10

# Комиссия стола
BATTLE_COMMISSION_PERCENT=10

# Цены фигур (за съеденную, Фаза 1)
PIECE_PRICE_PAWN=100
PIECE_PRICE_KNIGHT=300
PIECE_PRICE_BISHOP=300
PIECE_PRICE_ROOK=500
PIECE_PRICE_QUEEN=900
PIECE_PRICE_KING=1000

# Награды за победу над ботом
BOT_REWARD_1=1000
BOT_REWARD_2=2000
BOT_REWARD_3=3000
BOT_REWARD_4=4000
BOT_REWARD_5=5000
BOT_REWARD_6=6000
BOT_REWARD_7=7000
BOT_REWARD_8=8000
BOT_REWARD_9=9000
BOT_REWARD_10=10000
BOT_REWARD_11=11000
BOT_REWARD_12=12000
BOT_REWARD_13=13000
BOT_REWARD_14=14000
BOT_REWARD_15=15000
BOT_REWARD_16=16000
BOT_REWARD_17=17000
BOT_REWARD_18=18000
BOT_REWARD_19=19000
BOT_REWARD_20=20000

# Лиги — пороги баланса
LEAGUE_BRONZE=0
LEAGUE_SILVER=100000
LEAGUE_GOLD=1000000
LEAGUE_DIAMOND=5000000
LEAGUE_CHAMPION=10000000
LEAGUE_STAR=50000000

# ─────────────────────────────────────────
# МУЛЬТИСЕССИИ
# ─────────────────────────────────────────
MAX_ACTIVE_SESSIONS=3
MAX_BOT_SESSIONS=1
